PORT=5000
# Set this in Render's Environment Variables dashboard (not here) to enable keep-alive self-pinging.
# Example: RENDER_BACKEND_URL=https://brahmi-api.onrender.com
# RENDER_BACKEND_URL=
JWT_SECRET=your_jwt_secret_here

# Database URLs for production (Supabase / Neon)
# DATABASE_URL: Transaction Mode Pooler (port 6543, pgbouncer=true) - Used for general app queries
DATABASE_URL="your_database_url_here"

# DIRECT_URL: Session Mode Pooler (port 5432) - Used for Prisma migrations/db push
DIRECT_URL="your_direct_url_here"
